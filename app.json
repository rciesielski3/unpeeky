{
  "expo": {
    "name": "Unpeeky",
    "slug": "unpeeky",
    "version": "0.1.13",
    "orientation": "portrait",
    "icon": "./assets/images/Unpeeky_icon.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": ["**/*"],
    "splash": {
      "image": "./assets/images/Unpeeky_splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF8FF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.adateo.unpeeky"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/Unpeeky_adaptive-icon.png",
        "backgroundColor": "#EDE8FF"
      },
      "permissions": ["android.permission.RECORD_AUDIO"],
      "package": "com.adateo.unpeeky"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Pozwól Unpeeky wybrać zdjęcie nagrody z galerii.",
          "cameraPermission": "Pozwól Unpeeky zrobić zdjęcie nagrody."
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-4185040274135926~7754563632",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "19f067bf-0e6c-4e38-b653-9f147ab7e2b7"
      }
    },
    "owner": "adateo"
  }
}
