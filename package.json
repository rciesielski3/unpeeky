{
  "name": "unpeeky",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eas:build:android:internal": "npx eas build --platform android --profile internal",
    "eas:submit:android:internal": "npx eas submit --platform android --profile internal",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "postinstall": "patch-package",
    "test:unit": "node --import tsx --test src/domain/settings.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "expo": "~51.0.0",
    "expo-av": "~14.0.7",
    "expo-image-picker": "~15.1.0",
    "expo-notifications": "~0.28.19",
    "expo-status-bar": "~1.12.1",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-google-mobile-ads": "^14.7.2",
    "react-native-purchases": "^10.2.0",
    "react-native-reanimated": "~3.10.1",
    "react-native-safe-area-context": "4.10.5"
  },
  "devDependencies": {
    "@types/react": "~18.2.79",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-native": "^4.1.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.3",
    "tsx": "^4.22.4",
    "typescript": "~5.3.3"
  }
}
